<% layout('/layouts/boilerplate') %>
<br><br>
    <h3>All Queries</h3><br>
    <!-- <form action="listings/new" method="get">
        <button>Create New Listing</button>
    </form> -->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-11">
      <% for(let listing of allListings){ %>
        <a href="/listings/<%= listing._id %> 
          " class="listing-link">


          <div class="card" >
            <img class="card-img-top"
              src="<%= listing.image%>" 
              alt="Listing_image" 
              style="height: 20rem;">
          <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
                <b><%=listing.title %> </b><br>
                <%= listing.price%>
              </p>
            </div>
          </div>
        </a>
          <% } %>
    </div>