
<% layout('/layouts/boilerplate') %>
<div class="row">
    <div class="col-8 offset-2">
    <body>
        <h3 style="color: #fe424d;; padding-top: 2rem;">Create A new Listing</h3><br>
        <form action="/listings" method="post" novalidate class="needs-validation">
            <div class="mb-3">
                <label for="title" class="form-lable"><b>Title</b></label><br>
                <input type="text" name="listing[title]" placeholder="enter title" class="form-control" required><br>
                <div  class="valid-feedback">Title looks good</div>
            </div >
            <div class="mb-3">
                <label for="description" class="form-lable"><b>Description</b></label><br>
                <textarea name="listing[description]" placeholder="enter description" class="form-control"  required></textarea><br>
                <div  class="invalid-feedback">Description should be short</div>
            </div>
            <div class="row">
                <div  class="mb-3">
                    <label for="image" class="form-lable"><b>Image Link</b></label><br>
                    <input type="text" name="listing[image]" placeholder="enter img /URL link" class="form-control" ><br>
                    <div  class="invalid-feedback">Image path should be valid</div>
                </div>
                <div class="mb-3">
                    <label for="price" class="form-lable"><b>Price</b></label><br>
                    <input  name="listing[price]" placeholder="enter price" class="form-control"  required><br>
                    <div  class="invalid-feedback">Enter  Valid Price</div>
                </div >
                <div class=" mb-3">
                    <label for="location" class="form-lable"><b>Location</b></label><br>
                    <input type="text" name="listing[location]" placeholder="enter location" class="form-control"  required><br>
                    <div  class="invalid-feedback">Please Enter  Valid Location</div>
                </div>
            </div>
            <div class="mb-3">
                <label for="country" class="form-lable"><b>Country</b></label><br>
                <input type="text" name="listing[country]" placeholder="Add country" class="form-control"  required><br>
                <div  class="invalid-feedback">Please Enter Valid Country Name</div>
            </div>
            <button class="btn btn-dark edit-btn">ADD</button>
        </form>
        <script>// Example starter JavaScript for disabling form submissions if there are invalid fields
            (function () {
                'use strict'
              
                // Fetch all the forms we want to apply custom Bootstrap validation styles to
                var forms = document.querySelectorAll('.needs-validation')
              
                // Loop over them and prevent submission
                Array.prototype.slice.call(forms)
                  .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                      if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                      }
              
                      form.classList.add('was-validated')
                    }, false)
                  })
              })()</script>
    </body>
    </html>
</div>
</div>
