<% layout('/layouts/boilerplate') %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3><b>listings details </b></h3>
    </div>
    <br><br>
    <div class=" col-6 offset-2">
            <img class="card-img-top show-img" 
            src="<%= listing.image %>" 
            alt="listing image" > <br><br>
            <div class="card-body">
              <p class="card-text">
                <b><%= listing.title %></b><br>
                <%= listing.description %><br>
                &#8377; <%= listing.price.toLocaleString("en-IN")%></b><br>
                <%= listing.location %></b><br>
                <%= listing.country %></b><br>
            </p>
        </div>
    </div>
    <div class="btns mt-4">
        <a href="/listings/<%= listing._id %>/edit"
         class="btn btn-dark col-1 offset-2">Edit</a>
    <form method="post" action="/listings/<%=listing._id %>?_method=delete">
        <button class="btn btn-dark offset-5">Delete</button>
    </form>
</div>
</div>